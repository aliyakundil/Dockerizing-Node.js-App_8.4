# Dockerfile.dev
FROM node:18-alpine

# Install nodemon globally
RUN npm install -g nodemon

# Set working directory
WORKDIR /app

# Copy package files
COPY package*.json ./

# Install all dependencies (including dev)
RUN npm install

# Copy source code
COPY . .

# Expose port
EXPOSE 3000

# Use nodemon for development
CMD ["npm", "run", "dev"]
